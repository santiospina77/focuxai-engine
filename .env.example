# =============================================================================
# FocuxAI Engine — Environment Variables
# =============================================================================
# Copiar a .env.local para desarrollo y a Vercel Dashboard para producción.
# NUNCA commitear .env.local al repo.
# =============================================================================

# Logging
LOG_LEVEL=info  # debug | info | warn | error

# Cron secret — Vercel envía Authorization: Bearer ${CRON_SECRET} en cron jobs.
# Generar con: openssl rand -hex 32
CRON_SECRET=

# =============================================================================
# Cliente: jimenez_demo (portal demo de Focux con data Jiménez)
# =============================================================================

# Sinco (producción Jiménez)
SINCO_JIMENEZ_DEMO_USERNAME=APICBR
SINCO_JIMENEZ_DEMO_PASSWORD=

# HubSpot (portal demo de Focux)
HUBSPOT_JIMENEZ_DEMO_PRIVATE_APP_TOKEN=

# =============================================================================
# Cliente: jimenez (portal real de Constructora Jiménez)
# =============================================================================
# Activar cuando el setup en producción esté listo.

# SINCO_JIMENEZ_USERNAME=
# SINCO_JIMENEZ_PASSWORD=
# HUBSPOT_JIMENEZ_PRIVATE_APP_TOKEN=

# =============================================================================
# Cliente: urbansa (futuro)
# =============================================================================

# SINCO_URBANSA_USERNAME=
# SINCO_URBANSA_PASSWORD=
# HUBSPOT_URBANSA_PRIVATE_APP_TOKEN=
