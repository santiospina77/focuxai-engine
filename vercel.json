{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/engine/sync/inventory?clientId=jimenez_demo&mode=prices",
      "schedule": "0 6 * * *"
    }
  ],
  "functions": {
    "src/app/api/engine/sync/inventory/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/engine/sale/separar/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/engine/sale/legalizar/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/engine/quotations/pdf/route.tsx": {
      "maxDuration": 30
    },
    "src/app/api/engine/quotations/deal/route.ts": {
      "maxDuration": 30
    }
  }
}